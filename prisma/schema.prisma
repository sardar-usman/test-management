generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ProjectStatus {
  ACTIVE
  COMPLETED
  ON_HOLD
}

enum PlanStatus {
  DRAFT
  ACTIVE
  COMPLETED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum CaseStatus {
  DRAFT
  READY
  IN_PROGRESS
}

enum ExecutionStatus {
  NOT_RUN
  PASSED
  FAILED
  BLOCKED
  SKIPPED
}

model Project {
  id          String        @id @default(cuid())
  name        String
  description String?
  status      ProjectStatus @default(ACTIVE)
  createdBy   String
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  testPlans   TestPlan[]
  testCases   TestCase[]
}

model TestPlan {
  id          String      @id @default(cuid())
  projectId   String
  project     Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title       String
  description String?
  status      PlanStatus  @default(DRAFT)
  priority    Priority    @default(MEDIUM)
  startDate   DateTime?
  endDate     DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  links       TestPlanCase[]

  @@index([projectId])
}

model TestCase {
  id              String          @id @default(cuid())
  projectId       String
  project         Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  testCaseId      String          @unique
  title           String
  summary         String?
  preconditions   String?
  priority        Priority        @default(MEDIUM)
  status          CaseStatus      @default(DRAFT)
  executionStatus ExecutionStatus @default(NOT_RUN)
  assignedTo      String?
  tags            String[]
  createdBy       String
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  steps           TestStep[]
  links           TestPlanCase[]
  executions      TestExecution[]

  @@index([projectId])
  @@index([status])
  @@index([executionStatus])
}

model TestStep {
  id             String   @id @default(cuid())
  testCaseIdRef  String
  testCase       TestCase @relation(fields: [testCaseIdRef], references: [id], onDelete: Cascade)
  stepNo         Int
  action         String
  expectedResult String

  @@index([testCaseIdRef])
}

model TestPlanCase {
  id         String   @id @default(cuid())
  testPlanId String
  testCaseId String
  testPlan   TestPlan @relation(fields: [testPlanId], references: [id], onDelete: Cascade)
  testCase   TestCase @relation(fields: [testCaseId], references: [id], onDelete: Cascade)

  @@unique([testPlanId, testCaseId])
  @@index([testPlanId])
  @@index([testCaseId])
}

model TestExecution {
  id              String          @id @default(cuid())
  testCaseId      String
  testCase        TestCase        @relation(fields: [testCaseId], references: [id], onDelete: Cascade)
  executionStatus ExecutionStatus
  actualResult    String?
  comments        String?
  evidenceUrl     String?
  executedBy      String
  executedAt      DateTime        @default(now())

  @@index([testCaseId])
}

model ActivityLog {
  id        String   @id @default(cuid())
  type      String
  message   String
  actor     String
  createdAt DateTime @default(now())

  @@index([createdAt])
}
